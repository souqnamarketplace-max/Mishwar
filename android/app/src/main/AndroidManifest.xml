<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth deep-link callback. Used by Sign-in-with-Google:
                 src/lib/googleAuth.js opens the OAuth URL in
                 @capacitor/browser; Supabase redirects to
                 mishwaro://auth/callback when Google finishes; Android
                 sees the scheme + host registered here and routes the
                 URL to this activity instead of asking the user to
                 pick a handler. The appUrlOpen listener in
                 src/lib/native.js then parses the tokens out of the
                 fragment and calls supabase.auth.setSession.

                 The matching redirect URL must be whitelisted in the
                 Supabase dashboard under Authentication → URL
                 Configuration → Redirect URLs; without that, the
                 callback never reaches us because Supabase rejects
                 the redirect before Android gets involved.

                 autoVerify="false" because we're using a custom scheme,
                 not an https App Link — App Links would require us to
                 host an assetlinks.json on www.mishwaro.com and is
                 only needed if you want https://www.mishwaro.com/...
                 links to open the app instead of Chrome. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="mishwaro" android:host="auth" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- POST_NOTIFICATIONS is required on Android 13+ (API 33) for the
         app to display notifications, including FCM push. Without
         this, the runtime permission prompt never appears and FCM
         messages are silently dropped by the OS. Capacitor's
         @capacitor/push-notifications plugin requestPermissions()
         picks up this declaration and triggers the OS prompt. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Location — used by chat "share my location" and by trip
         pickup-coordinate capture. navigator.geolocation in the
         WebView proxies through these permissions. We declare both
         FINE (GPS, precise to metres) and COARSE (cell + wifi, ~100m)
         so the OS can fall back gracefully when GPS is unavailable.
         The runtime prompt fires the first time getCurrentPosition
         is called. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Camera — used by chat "take photo" capture and the selfie
         verification flow. Without this declaration, the
         <input capture="environment"> file picker can't access the
         camera, and the picker falls back to gallery-only on some
         devices. -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Storage reads — needed for the gallery picker on Android 12-
         and below. Android 13+ uses scoped storage with READ_MEDIA_*
         permissions instead; we declare both so the manifest works
         across the full version range. The OS auto-selects the right
         one based on targetSdkVersion. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
                     android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
</manifest>
