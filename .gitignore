# Capacitor — platform projects are generated by `npx cap add` and
# should be regenerated locally / on CI rather than committed. The
# Capacitor — track platform projects in git (standard pattern) so iOS
# Info.plist permission strings, Android manifest config, and project-
# settings changes persist across machines and CI. EXCLUDE generated
# subdirs that the build tools regenerate on every install:
#
#   ios/Pods/                      — CocoaPods downloads (run `pod install`)
#   ios/App/Pods/                  — old-style Pods location
#   ios/App/build/                 — Xcode build artifacts
#   ios/App/output/                — archive output
#   ios/DerivedData/               — Xcode caches
#   ios/App/App/public/            — Capacitor copies dist/ here on cap sync
#   android/.gradle/               — Gradle caches
#   android/.idea/                 — Android Studio per-user settings
#   android/build/                 — Gradle build outputs
#   android/app/build/             — App module build output
#   android/local.properties       — machine-specific SDK paths
#   android/app/release/           — signed APK output
#   android/app/src/main/assets/public/  — capacitor sync dest
#
# capacitor.config.ts at repo root is the source of truth for shared
# config; per-platform overrides go in Info.plist / AndroidManifest.xml
# which ARE tracked.
ios/Pods/
ios/App/Pods/
ios/App/build/
ios/App/output/
ios/DerivedData/
ios/App/App/public/
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/local.properties
android/app/release/
android/app/src/main/assets/public/
.capacitor/

# Supabase CLI working files — never commit
supabase/.temp/
